#!/usr/bin/env bash
# .githooks/pre-push
#
# Prevents pushing to a branch that is already merged into origin/main.
# This catches the recurring mistake of reusing merged feature branches.
#
# Install: git config core.hooksPath .githooks
# (The repo's .git/config is updated by scripts/setup-hooks.sh)

set -euo pipefail

REMOTE="$1"      # e.g. "origin"
REMOTE_URL="$2"  # e.g. "https://github.com/..."

# Read pushed refs from stdin: <local_ref> <local_sha> <remote_ref> <remote_sha>
while read -r local_ref local_sha remote_ref remote_sha; do
  # Only check branch pushes (skip tag pushes and deletions)
  [[ "$local_sha" == "0000000000000000000000000000000000000000" ]] && continue
  [[ "$remote_ref" != refs/heads/* ]] && continue

  branch="${remote_ref#refs/heads/}"

  # Skip main itself
  [[ "$branch" == "main" ]] && continue

  # Fetch latest merged branch info from origin (quietly)
  git fetch origin main --quiet 2>/dev/null || true

  # Check if this branch is already merged into origin/main
  if git branch -r --merged origin/main 2>/dev/null | grep -qE "^\s*origin/${branch}$"; then
    echo ""
    echo "✗ PUSH BLOCKED: 'origin/${branch}' is already merged into main."
    echo ""
    echo "  Pushing to a merged branch will create a stale / diverged branch."
    echo "  Start fresh off main instead:"
    echo ""
    echo "    git checkout main && git pull origin main"
    echo "    git checkout -b fix/<new-description>"
    echo ""
    exit 1
  fi
done

exit 0
